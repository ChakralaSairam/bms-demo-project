								"value": "Bearer {{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/admin/shows",
							"host": ["{{baseUrl}}"],
							"path": ["api", "admin", "shows"]
						}
					}
				},
				{
					"name": "Create Show",
					"request": {
						"method": "POST",
						"header": [
