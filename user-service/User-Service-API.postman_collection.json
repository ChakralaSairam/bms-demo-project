		{
			"name": "Internal API (For Go Service)",
			"item": [
				{
					"name": "Get Booked Seats for Show",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/internal/shows/1/booked-seats",
							"host": ["{{baseUrl}}"],
							"path": ["internal", "shows", "1", "booked-seats"]
