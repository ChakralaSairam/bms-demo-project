								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{adminToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"movieId\": 1,\n  \"theaterId\": 1,\n  \"startTime\": \"2024-03-01T19:00:00\",\n  \"price\": 350.00\n}"
						},
						"url": {
